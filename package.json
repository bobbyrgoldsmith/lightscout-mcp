{
  "name": "lightscout-mcp",
  "version": "0.1.2",
  "description": "MCP server for Core Web Vitals analysis powered by Lighthouse. Part of the TestScout MCP Suite.",
  "type": "module",
  "bin": {
    "lightscout-mcp": "dist/index.js",
    "lightscout": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "find node_modules -name '* *' -depth -exec rm -rf {} + 2>/dev/null; rm -rf node_modules yarn.lock",
    "build": "tsup",
    "dev": "tsup --watch",
    "verify": "node -e \"require('lighthouse/package.json'); require('tsup/package.json'); console.log('deps ok')\"",
    "test": "vitest run",
    "postinstall": "node -e \"require('fs').writeFileSync('node_modules/.metadata_never_index','')\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "lighthouse",
    "core-web-vitals",
    "performance",
    "testscout",
    "web-performance",
    "cwv"
  ],
  "author": "Bobby Goldsmith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobbyrgoldsmith/lightscout-mcp.git"
  },
  "homepage": "https://testscout.dev",
  "bugs": {
    "url": "https://github.com/bobbyrgoldsmith/lightscout-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.1",
    "lighthouse": "^11.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
